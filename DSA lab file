//// ================= PROGRAM 2: SLL =================
struct node{
    int data;
    struct node* next;
};

void program2(){
    struct node* head=NULL;
    int ch,val;

    do{
        printf("\n--- SLL MENU ---");
        printf("\n1.Insert\n2.Display\n3.Exit\nChoice: ");
        scanf("%d",&ch);

        if(ch==1){
            struct node* newnode=malloc(sizeof(struct node));
            printf("Enter value: ");
            scanf("%d",&val);
            newnode->data=val;
            newnode->next=head;
            head=newnode;
        }
        else if(ch==2){
            struct node* temp=head;
            while(temp){
                printf("%d ",temp->data);
                temp=temp->next;
            }
            printf("\n");
        }
    }while(ch!=3);
}

//// ================= PROGRAM 3: STACK ARRAY =================
void program3(){
    int stack[5], top=-1, ch,val;

    do{
        printf("\n--- STACK MENU ---");
        printf("\n1.Push\n2.Pop\n3.Display\n4.Exit\nChoice: ");
        scanf("%d",&ch);

        switch(ch){
            case 1:
                if(top==4) printf("Full\n");
                else{
                    scanf("%d",&val);
                    stack[++top]=val;
                }
                break;
            case 2:
                if(top==-1) printf("Empty\n");
                else printf("Popped %d\n",stack[top--]);
                break;
            case 3:
                for(int i=top;i>=0;i--) printf("%d ",stack[i]);
                printf("\n");
        }
    }while(ch!=4);
}

//// ================= PROGRAM 4: STACK LL =================
struct stacknode{
    int data;
    struct stacknode* next;
};

void program4(){
    struct stacknode* top=NULL;
    int ch,val;

    do{
        printf("\n--- STACK LL ---");
        printf("\n1.Push\n2.Pop\n3.Display\n4.Exit\nChoice: ");
        scanf("%d",&ch);

        if(ch==1){
            struct stacknode* newnode=malloc(sizeof(struct stacknode));
            scanf("%d",&val);
            newnode->data=val;
            newnode->next=top;
            top=newnode;
        }
        else if(ch==2){
            if(top==NULL) printf("Empty\n");
            else{
                printf("Popped %d\n",top->data);
                top=top->next;
            }
        }
        else if(ch==3){
            struct stacknode* temp=top;
            while(temp){
                printf("%d ",temp->data);
                temp=temp->next;
            }
            printf("\n");
        }
    }while(ch!=4);
}

//// ================= PROGRAM 5: CIRCULAR QUEUE =================
void program5(){
    int q[5], front=-1,rear=-1,ch,val;

    do{
        printf("\n--- CIRCULAR QUEUE ---");
        printf("\n1.Insert\n2.Delete\n3.Display\n4.Exit\nChoice: ");
        scanf("%d",&ch);

        if(ch==1){
            if((rear+1)%5==front) printf("Full\n");
            else{
                scanf("%d",&val);
                if(front==-1) front=0;
                rear=(rear+1)%5;
                q[rear]=val;
            }
        }
        else if(ch==2){
            if(front==-1) printf("Empty\n");
            else{
                printf("Deleted %d\n",q[front]);
                if(front==rear) front=rear=-1;
                else front=(front+1)%5;
            }
        }
        else if(ch==3){
            if(front==-1) printf("Empty\n");
            else{
                int i=front;
                while(1){
                    printf("%d ",q[i]);
                    if(i==rear) break;
                    i=(i+1)%5;
                }
                printf("\n");
            }
        }
    }while(ch!=4);
}

//// ================= PROGRAM 6: QUEUE LL =================
struct qnode{
    int data;
    struct qnode* next;
};

void program6(){
    struct qnode *front=NULL,*rear=NULL;
    int ch,val;

    do{
        printf("\n--- QUEUE LL ---");
        printf("\n1.Insert\n2.Delete\n3.Display\n4.Exit\nChoice: ");
        scanf("%d",&ch);

        if(ch==1){
            struct qnode* newnode=malloc(sizeof(struct qnode));
            scanf("%d",&val);
            newnode->data=val;
            newnode->next=NULL;

            if(rear==NULL) front=rear=newnode;
            else{
                rear->next=newnode;
                rear=newnode;
            }
        }
        else if(ch==2){
            if(front==NULL) printf("Empty\n");
            else{
                printf("Deleted %d\n",front->data);
                front=front->next;
            }
        }
        else if(ch==3){
            struct qnode* temp=front;
            while(temp){
                printf("%d ",temp->data);
                temp=temp->next;
            }
            printf("\n");
        }
    }while(ch!=4);
}

//// ================= PROGRAM 7: DLL =================
struct dnode{
    int data;
    struct dnode *prev,*next;
};

void program7(){
    struct dnode* head=NULL;
    int ch,val;

    do{
        printf("\n--- DLL ---");
        printf("\n1.Insert\n2.Display\n3.Exit\nChoice: ");
        scanf("%d",&ch);

        if(ch==1){
            struct dnode* newnode=malloc(sizeof(struct dnode));
            scanf("%d",&val);
            newnode->data=val;
            newnode->prev=NULL;
            newnode->next=head;
            if(head) head->prev=newnode;
            head=newnode;
        }
        else if(ch==2){
            struct dnode* temp=head;
            while(temp){
                printf("%d ",temp->data);
                temp=temp->next;
            }
            printf("\n");
        }
    }while(ch!=3);
}

