//// ================= PROGRAM 9: BST TRAVERSAL =================
struct bst{
    int data;
    struct bst *left,*right;
};

struct bst* insertBST(struct bst* root,int val){
    if(root==NULL){
        root=malloc(sizeof(struct bst));
        root->data=val;
        root->left=root->right=NULL;
        return root;
    }
    if(val<root->data) root->left=insertBST(root->left,val);
    else root->right=insertBST(root->right,val);
    return root;
}

void inorder(struct bst* root){
    if(root){
        inorder(root->left);
        printf("%d ",root->data);
        inorder(root->right);
    }
}

void program9(){
    struct bst* root=NULL;
    int n,val;
    printf("Enter nodes: ");
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        scanf("%d",&val);
        root=insertBST(root,val);
    }
    inorder(root);
}

