//// ================= PROGRAM 1: ARRAY =================
void program1(){
    int arr[100], n=0, ch, val, pos;

    do{
        printf("\n--- ARRAY MENU ---");
        printf("\n1.Insert\n2.Display\n3.Exit\nChoice: ");
        scanf("%d",&ch);

        switch(ch){
            case 1:
                printf("Enter value: ");
                scanf("%d",&val);
                arr[n++] = val;
                break;
            case 2:
                for(int i=0;i<n;i++) printf("%d ",arr[i]);
                printf("\n");
        }
