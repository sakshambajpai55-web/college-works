abstract class Shape {
    abstract void area();
}

class Rectangle extends Shape {
    int l = 5, b = 3;

    void area() {
        System.out.println("Area of Rectangle = " + (l * b));
    }
}

public class AbstractDemo {
    public static void main(String[] args) {
        Shape obj = new Rectangle();
        obj.area();
    }
}
