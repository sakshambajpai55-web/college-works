#include<stdio.h>

int main(){
    int n,arr[100],key,found=0;
    printf("Enter size: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++) scanf("%d",&arr[i]);

    printf("Enter key: ");
    scanf("%d",&key);

    // Linear Search
    for(int i=0;i<n;i++)
        if(arr[i]==key){ printf("Found (Linear)\n"); found=1; break; }

    // Binary Search (Sorted required)
    int low=0,high=n-1,mid;
    while(low<=high){
        mid=(low+high)/2;
        if(arr[mid]==key){ printf("Found (Binary)\n"); break; }
        else if(arr[mid]<key) low=mid+1;
        else high=mid-1;
    }
}
