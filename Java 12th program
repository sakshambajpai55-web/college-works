class BankAccount {
    double balance = 1000;

    void withdraw(double amount) {
        if (amount <= balance) {
            balance -= amount;
            System.out.println("Withdraw successful");
        } else {
            System.out.println("Insufficient balance");
        }
    }
}

public class BankDemo {
    public static void main(String[] args) {
        BankAccount b = new BankAccount();
        b.withdraw(500);
    }
}
